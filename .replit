modules = ["nodejs-20", "web", "bun"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0", "javascript_log_in_with_replit:2.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
MASTER_ADMIN_ID = "60287485"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun server/index.ts & bunx vite dev"
waitForPort = 5000

[[ports]]
localPort = 4444
externalPort = 3002

[[ports]]
localPort = 4446
externalPort = 4200

[[ports]]
localPort = 4447
externalPort = 5000

[[ports]]
localPort = 4448
externalPort = 5173

[[ports]]
localPort = 4449
externalPort = 6000

[[ports]]
localPort = 4450
externalPort = 6800

[[ports]]
localPort = 4451
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3003

[[ports]]
localPort = 5003
externalPort = 3001

[[ports]]
localPort = 5004
externalPort = 8008

[deployment]
deploymentTarget = "autoscale"
run = ["bun", "server/index.ts"]
build = ["bun", "run", "build"]
